# Server
PORT=8080
APP_ENV=development

# PostgreSQL — for Docker Compose use the service name as host
DATABASE_URL=postgres://postgres:postgres@postgresql:5432/supportiq?sslmode=disable

# JWT secrets — replace with long random strings in production
JWT_ACCESS_SECRET=replace_with_a_strong_access_secret
JWT_REFRESH_SECRET=replace_with_a_strong_refresh_secret

# AI providers (optional — features degrade gracefully if not set)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_TIMEOUT=30
AI_MAX_RETRIES=2
MAX_REPLY_TOKENS=1024
REPLY_TEMPERATURE=0.3

# Redis (optional — job queue degrades gracefully if not set)
REDIS_URL=redis://redis:6379
QUEUE_NAME=ai_jobs
WORKER_COUNT=3
MAX_RETRIES=3
RETRY_DELAY=5

# WebSocket / CORS — must match the URL the frontend is served from
WEBSOCKET_ORIGIN=http://localhost:80
APP_URL=http://localhost:80

# Email integration (optional — configured per-tenant in the UI)
EMAIL_POLL_INTERVAL=60
MAX_EMAIL_RETRIES=3

# Storage paths (relative to working directory inside the container)
ATTACHMENT_PATH=./storage/attachments
REPORT_STORAGE_PATH=./storage/reports
REPORT_RETENTION_DAYS=30

# Analytics
METRICS_REFRESH_INTERVAL=3600

# Integrations
INTEGRATION_POLL_INTERVAL=30
WEBHOOK_SECRET=
